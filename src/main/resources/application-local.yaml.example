# Copy this file to application-local.yaml and fill in your local values.
# application-local.yaml is gitignored and will never be committed.
spring:
  datasource:
    username: postgres
    password: your-password-here

bump:
  security:
    jwt:
      # Generate a secret with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
      secret: your-base64-encoded-secret-here

# Enables OpenAPI/Swagger UI as developer tool.
springdoc:
  api-docs:
    enabled: true
  swagger-ui:
    enabled: true
